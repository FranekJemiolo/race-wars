FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY client/package*.json ./client/
COPY shared/package*.json ./shared/

# Install dependencies
RUN npm ci

# Copy source code
COPY client/ ./client/
COPY shared/ ./shared/

# Build shared package
RUN npm run build:shared

# Expose port
EXPOSE 5173

# Start command
CMD ["npm", "run", "dev:client"]
