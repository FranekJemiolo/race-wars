{
  "name": "race-wars",
  "description": "Race against friends using GPS. Create teams, compete on real roads, and see live leaderboards during races.",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "screenshots:generate": "ts-node scripts/generate-screenshots.ts",
    "screenshots:install": "npx playwright install",
    "screenshots:test": "playwright test --config=playwright.screenshots.config.ts",
    "test:behavioral": "jest tests/integration/**/*.behavioral.spec.ts --passWithNoTests",
    "test:behavioral:watch": "jest tests/integration/**/*.behavioral.spec.ts --watch --passWithNoTests",
    "test:behavioral:coverage": "jest tests/integration/**/*.behavioral.spec.ts --coverage --passWithNoTests",
    "test:unit": "jest tests/unit/**/*.spec.ts --passWithNoTests",
    "test:all": "jest tests/**/*.spec.ts --passWithNoTests",
    "lint": "npm run lint:server && npm run lint:client && npm run lint:shared || true",
    "lint:server": "npm --workspace server run lint || true",
    "lint:client": "npm --workspace client run lint || true",
    "lint:shared": "npm --workspace shared run lint || true",
    "type-check": "npm run type-check:server && npm run type-check:client && npm run type-check:shared || true",
    "type-check:server": "npm --workspace server run type-check || true",
    "type-check:client": "npm --workspace client run type-check || true",
    "type-check:shared": "npm --workspace shared run type-check || true",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "build:shared": "npm run -w shared build || true",
    "build:server": "npm run -w server build || true",
    "build:client": "npm run -w client build || true",
    "ci:build": "npm run build",
    "ci:test": "npm run test:behavioral && npm run test:e2e || true",
    "ci:lint": "npm run lint",
    "ci:type-check": "npm run type-check",
    "dev:setup": "node scripts/dev-setup.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:shared\"",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker-compose -f docker-compose.dev.yml down",
    "dev:simple": "npm run dev:setup && npm run dev:server"
  },
  "dependencies": {
    "@turf/helpers": "^7.3.5",
    "@turf/turf": "^7.3.5",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^8.2.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "puppeteer": "^24.42.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  }
}
