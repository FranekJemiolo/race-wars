{
  "name": "race-wars",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "build": "npm run -w shared build && npm run -w server build && npm run -w client build",
    "build:shared": "npm run -w shared build",
    "build:server": "npm run -w server build",
    "build:client": "npm run -w client build"
  },
  "dependencies": {
    "@turf/helpers": "^7.3.5",
    "@turf/turf": "^7.3.5",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
