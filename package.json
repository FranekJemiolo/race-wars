{
  "name": "race-wars",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "test:e2e": "npm --workspace client run test:e2e",
    "test:e2e:ui": "npm --workspace client run test:e2e:ui",
    "build": "npm run -w shared build && npm run -w server build && npm run -w client build",
    "build:shared": "npm run -w shared build",
    "build:server": "npm run -w server build",
    "build:client": "npm run -w client build"
  }
}
