# Local Development Environment Configuration
# Copy this file to .env.local and fill in the actual values

# Application
NODE_ENV=development
PORT=8080

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=race_wars_dev
DB_USER=race_wars
DB_PASSWORD=race_wars_dev

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Security (Development values - change for production)
JWT_SECRET=dev_jwt_secret_key_change_in_production
BCRYPT_ROUNDS=10

# Monitoring & Logging
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=debug

# OAuth Configuration (Optional for local development)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=

# Firebase Configuration (Optional for local development)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Email Configuration (Optional for local development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=dev@racewars.local

# File Storage (Local development)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Client Configuration
REACT_APP_API_URL=http://localhost/api
REACT_APP_WS_URL=ws://localhost/ws
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# Monitoring Credentials (Local defaults)
GRAFANA_PASSWORD=admin

# Development Settings
HOT_RELOAD=true
DEBUG_MODE=true
ENABLE_CORS=true
