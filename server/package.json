{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "simulation": "ts-node --transpile-only src/simulation/runSimulation.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "ts-node --transpile-only src/cli/migrate.ts",
    "migrate:up": "npm run migrate up",
    "migrate:status": "npm run migrate status",
    "migrate:rollback": "npm run migrate rollback",
    "migrate:create": "npm run migrate create"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-jaeger": "^1.17.0",
    "@opentelemetry/resources": "^1.17.0",
    "@opentelemetry/sdk-trace-base": "^1.17.0",
    "@opentelemetry/sdk-trace-node": "^1.17.0",
    "@opentelemetry/semantic-conventions": "^1.17.0",
    "@race-wars/shared": "*",
    "@sentry/node": "^7.80.0",
    "@sentry/profiling-node": "^1.3.0",
    "@turf/turf": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "nats": "^2.20.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^4.6.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.0",
    "eslint": "^8.57.0",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
